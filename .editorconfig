root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

# File-scoped namespaces everywhere (already the convention in this repo)
csharp_style_namespace_declarations = file_scoped:warning

# var only where the type is obvious from the right-hand side
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members for simple one-liners, block bodies otherwise
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# using directives outside the namespace, System.* first (matches every file already)
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true

# Braces required for multi-line bodies, allowed on one line for single-statement guards
# (matches the existing style, e.g. "if (!resp.IsSuccessStatusCode) return null;")
csharp_prefer_braces = when_multiline:suggestion

# Naming: private fields as _camelCase (already the convention, e.g. _tokenLock, _http)
dotnet_naming_rule.private_fields_underscore_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_underscore_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_underscore_camel_case.style = underscore_camel_case
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
