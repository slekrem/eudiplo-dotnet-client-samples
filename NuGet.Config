<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Pins package restore to nuget.org only, regardless of what a contributor's machine-wide
       NuGet.Config defines (e.g. a private company feed) — keeps builds of this public repo
       reproducible for everyone who clones it. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
