# Copy to .env, fill in real values, then: docker compose up -d
# Mirrors EUDIPLO's own "minimal" deployment profile
# (deployment/docker-compose/.env.minimal.example upstream) — SQLite + local file
# storage, no Postgres/MinIO/Vault needed.

PUBLIC_URL=http://localhost:3000

# Required, no defaults — EUDIPLO refuses to start without these.
# Generate MASTER_SECRET: openssl rand -base64 32
MASTER_SECRET=replace-with-32+-random-characters
# AUTH_CLIENT_ID / AUTH_CLIENT_SECRET become the tenant-less ROOT client's credentials —
# export these same two values before running the sample (see README.md).
AUTH_CLIENT_ID=sample-root-client
AUTH_CLIENT_SECRET=replace-with-a-real-secret

DB_TYPE=sqlite
KM_TYPE=db
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=/app/uploads
